{
  "name": "supra-ts-sdk",
  "version": "1.0.0",
  "description": "A TypeScript SDK for interacting with the Supra blockchain and Move smart contracts. Provides type-safe utilities for transactions, contract calls, and on-chain data.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "doc": "typedoc --out docs src/index.ts --sort source-order --sort instance-first --readme README.md",
    "test:file": "npx tsx src/test.ts"
  },
  "keywords": [
    "supra",
    "supra-ts-sdk",
    "supra-l1-sdk",
    "supra-l1",
    "supra-blockchain",
    "supra-sdk",
    "supra-typescript",
    "supra-javascript",
    "move",
    "move-lang",
    "move-smart-contracts",
    "move-sdk",
    "blockchain",
    "web3",
    "web3-sdk",
    "crypto",
    "dapp",
    "dapp-development",
    "smart-contracts",
    "typescript-sdk",
    "javascript-sdk"
  ],
  "author": "Supra",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "js-sha3": "^0.9.3",
    "supra-l1-sdk-core": "^2.0.1"
  }
}