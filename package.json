{
  "name": "supra-ts-sdk",
  "version": "1.0.0",
  "description": "A TypeScript SDK for interacting with the Supra blockchain and Move smart contracts. Provides type-safe utilities for transactions, contract calls, and on-chain data.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Entropy-Foundation/supra-ts-sdk.git"
  },
  "homepage": "https://github.com/Entropy-Foundation/supra-ts-sdk#readme",
  "bugs": {
    "url": "https://github.com/Entropy-Foundation/supra-ts-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    ".claude/skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm build",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json",
    "doc": "typedoc --out docs src/index.ts --sort source-order --sort instance-first --readme README.md"
  },
  "keywords": [
    "supra",
    "supra-ts-sdk",
    "supra-l1-sdk",
    "supra-l1",
    "supra-blockchain",
    "supra-sdk",
    "supra-typescript",
    "supra-javascript",
    "move",
    "move-lang",
    "move-smart-contracts",
    "move-sdk",
    "blockchain",
    "web3",
    "web3-sdk",
    "crypto",
    "dapp",
    "dapp-development",
    "smart-contracts",
    "typescript-sdk",
    "javascript-sdk"
  ],
  "author": "Supra",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "js-sha3": "^0.9.3",
    "supra-l1-sdk-core": "^2.0.1"
  },
  "pnpm": {
    "overrides": {
      "@jest/transform": "^29.7.0",
      "babel-jest": "^29.7.0",
      "jest-util": "^29.7.0",
      "@jest/types": "^29.6.3",
      "handlebars": "^4.7.9",
      "brace-expansion@1": "^1.1.12",
      "brace-expansion@2": "^2.0.2",
      "picomatch": "^4.0.4",
      "flatted": "^3.4.2"
    }
  }
}